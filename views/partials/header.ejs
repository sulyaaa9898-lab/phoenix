<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Phoenix Center</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body data-open-modal="<%= typeof openModalId !== 'undefined' ? openModalId : '' %>">
    <div class="shell">
      <aside class="sidebar">
        <div>
          <h1>Phoenix</h1>
        </div>

        <nav class="sidebar-nav" id="sidebar-nav">
          <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>" title="Dashboard">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span>
            <span class="nav-label">Dashboard</span>
          </a>
          <a href="/students" class="<%= currentPath === '/students' ? 'active' : '' %>" title="Ученики">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
            <span class="nav-label">Ученики</span>
          </a>
          <a href="/teachers" class="<%= currentPath === '/teachers' ? 'active' : '' %>" title="Преподаватели">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10L12 5 2 10l10 5 10-5z"/><path d="M6 12v4c0 2 2.7 4 6 4s6-2 6-4v-4"/></svg></span>
            <span class="nav-label">Преподаватели</span>
          </a>
          <a href="/groups" class="<%= currentPath === '/groups' ? 'active' : '' %>" title="Группы">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
            <span class="nav-label">Группы</span>
          </a>
          <a href="/schedules" class="<%= currentPath === '/schedules' ? 'active' : '' %>" title="Расписание занятий">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span>
            <span class="nav-label">Расписание занятий</span>
          </a>
          <a href="/tariffs" class="<%= currentPath === '/tariffs' ? 'active' : '' %>" title="Тарифы">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg></span>
            <span class="nav-label">Тарифы</span>
          </a>
          <a href="/payments" class="<%= currentPath === '/payments' ? 'active' : '' %>" title="Оплаты">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
            <span class="nav-label">Оплаты</span>
          </a>
          <a href="/teacher-timesheet" class="<%= currentPath === '/teacher-timesheet' ? 'active' : '' %>" title="График и табель">
            <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/><line x1="2" y1="20" x2="22" y2="20"/></svg></span>
            <span class="nav-label">График и табель</span>
          </a>
        </nav>
      </aside>

      <main class="content">
        <header class="page-header">
          <div>
            <p class="eyebrow"><%= title %></p>
            <h2><%= heading %></h2>
          </div>
        </header>

        <% if (flash) { %>
          <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
        <% } %>